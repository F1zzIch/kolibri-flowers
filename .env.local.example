# Скопируй этот файл в .env.local и подставь свои значения.
# .env.local не коммитится (см. .gitignore).

# --- Supabase (Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Секретный ключ для записи ботом (НЕ публиковать, без префикса NEXT_PUBLIC_):
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Telegram-бот управления каталогом ---
# Токен бота от @BotFather:
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Кому разрешено управлять (числовые Telegram ID через запятую), узнать у @userinfobot:
TELEGRAM_ADMIN_IDS=123456789
# Секрет для защиты webhook-эндпоинта (любая случайная строка):
TELEGRAM_WEBHOOK_SECRET=set-a-long-random-string

# --- Сайт ---
# Базовый URL (для SEO/метаданных и установки webhook), напр. https://kolibri-flowers.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
